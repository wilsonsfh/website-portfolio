---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import WorkExperienceCard from "../components/WorkExperienceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ActivityCard from "../components/ActivityCard.astro";
import ContactSection from "../components/ContactSection.astro";
import ScrollReveal from "../components/ScrollReveal.astro";

import workExperienceData from "../data/work-experience.json";
import projectsData from "../data/projects.json";
import activitiesData from "../data/activities.json";
---

<Layout>
  <Navbar />
  <main>
    <Hero />

    <About />


    <!-- Work Experience Section -->
    <section id="work-experience" class="py-20 bg-background dark:bg-background-dark">
      <div class="max-w-site mx-auto px-6">
        <div class="scroll-reveal">
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-foreground dark:text-foreground-dark mb-12">
            work experience
          </h2>
        </div>
        <div class="space-y-6">
          {workExperienceData.map((exp, i) => (
            <ScrollReveal delay={i * 100}>
              <WorkExperienceCard {...exp} />
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>



    <!-- Projects Section -->
    <section id="projects" class="py-20 bg-background-alt dark:bg-background-dark-alt">
      <div class="max-w-site mx-auto px-6">
        <div class="scroll-reveal">
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-foreground dark:text-foreground-dark mb-12">
            projects
          </h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {projectsData.map((project, i) => (
            <ScrollReveal delay={i * 100}>
              <ProjectCard {...project} />
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>



    <!-- Activities Section -->
    <section id="activities" class="py-20 bg-background dark:bg-background-dark">
      <div class="max-w-site mx-auto px-6">
        <div class="scroll-reveal">
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-foreground dark:text-foreground-dark mb-12">
            activities & involvement
          </h2>
        </div>
        <div class="space-y-6">
          {activitiesData.map((activity, i) => (
            <ScrollReveal delay={i * 100}>
              <ActivityCard {...activity} />
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>



    <!-- Blog Section -->
    <section id="blog" class="py-20 bg-background dark:bg-background-dark">
      <div class="max-w-site mx-auto px-6">
        <div class="scroll-reveal">
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-foreground dark:text-foreground-dark mb-4">
            blog
          </h2>
          <div class="bg-background-alt dark:bg-background-dark-alt rounded-xl p-12 text-center border border-foreground/5 dark:border-foreground-dark/10">
            <p class="text-4xl mb-4">&#9997;&#65039;</p>
            <p class="text-foreground dark:text-foreground-dark font-heading font-semibold text-xl mb-2">
              stay tuned — writing in progress
            </p>
            <p class="text-foreground-muted dark:text-foreground-dark-muted">
              i'm working on some posts about tech, product, and everything in between. check back soon!
            </p>
          </div>
        </div>
      </div>
    </section>



    <ContactSection />
  </main>

  <!-- Floating navigation buttons -->
  <button
    id="prev-section-btn"
    aria-label="Scroll to previous section"
    class="fixed bottom-20 right-6 z-40 w-12 h-12 rounded-full bg-accent dark:bg-accent-dark text-white flex items-center justify-center shadow-lg hover:bg-accent-hover dark:hover:bg-accent-dark-hover transition-all duration-200 hover:scale-105 animate-bounce hidden"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
    </svg>
  </button>
  <button
    id="next-section-btn"
    aria-label="Scroll to next section"
    class="fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full bg-accent dark:bg-accent-dark text-white flex items-center justify-center shadow-lg hover:bg-accent-hover dark:hover:bg-accent-dark-hover transition-all duration-200 hover:scale-105 animate-bounce"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
</Layout>

<script>
  // Scroll reveal using Intersection Observer
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );

    document.querySelectorAll(".scroll-reveal").forEach((el) => {
      observer.observe(el);
    });
  } else {
    document.querySelectorAll(".scroll-reveal").forEach((el) => {
      el.classList.add("revealed");
    });
  }
</script>

<script>
  // Floating navigation buttons logic
  const sectionIds = ["hero", "about", "work-experience", "projects", "activities", "blog", "contact"];
  const nextBtn = document.getElementById("next-section-btn");
  const prevBtn = document.getElementById("prev-section-btn");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const scrollBehavior = prefersReduced ? "auto" : "smooth";

  if (nextBtn && prevBtn) {
    let currentIndex = 0;
    let isManualScrolling = false;
    let manualScrollTimer: ReturnType<typeof setTimeout>;

    function updateButtons(idx: number) {
      currentIndex = idx;
      const lastIndex = sectionIds.length - 1;

      // Hide up button on hero (index 0)
      if (idx <= 0) {
        prevBtn!.classList.add("hidden");
      } else {
        prevBtn!.classList.remove("hidden");
      }

      // Hide down button on contact (last index)
      if (idx >= lastIndex) {
        nextBtn!.classList.add("hidden");
      } else {
        nextBtn!.classList.remove("hidden");
      }
    }

    function getActiveSection(): number {
      let active = 0;
      for (let i = 0; i < sectionIds.length; i++) {
        const el = document.getElementById(sectionIds[i]);
        if (!el) continue;
        if (el.getBoundingClientRect().top <= 80) active = i;
      }
      return active;
    }

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking && !isManualScrolling) {
        requestAnimationFrame(() => {
          updateButtons(getActiveSection());
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    nextBtn.addEventListener("click", () => {
      if (currentIndex < sectionIds.length - 1) {
        const targetIdx = currentIndex + 1;
        updateButtons(targetIdx);
        isManualScrolling = true;
        clearTimeout(manualScrollTimer);
        manualScrollTimer = setTimeout(() => {
          isManualScrolling = false;
          updateButtons(getActiveSection());
        }, 1000);
        document.getElementById(sectionIds[targetIdx])?.scrollIntoView({ behavior: scrollBehavior });
      }
    });

    prevBtn.addEventListener("click", () => {
      if (currentIndex > 0) {
        const targetIdx = currentIndex - 1;
        updateButtons(targetIdx);
        isManualScrolling = true;
        clearTimeout(manualScrollTimer);
        manualScrollTimer = setTimeout(() => {
          isManualScrolling = false;
          updateButtons(getActiveSection());
        }, 1000);
        document.getElementById(sectionIds[targetIdx])?.scrollIntoView({ behavior: scrollBehavior });
      }
    });
  }
</script>
