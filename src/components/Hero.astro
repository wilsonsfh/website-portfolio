---
import TypewriterText from "./TypewriterText.astro";

const typewriterWords = [
  "software engineer",
  "product manager",
  "dancer",
  "fullstack developer",
  "nature lover",
  "tea lover",
  "singaporean",
  "photographer",
  "rock climb beginner",
  "volleyball beginner",

];
---

<section id="hero" class="min-h-screen flex items-center pt-20 bg-background dark:bg-background-dark relative overflow-hidden">
  <!-- Gradient background blobs -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-accent/20 dark:bg-accent-dark/15 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 right-20 w-96 h-96 bg-amber-400/15 dark:bg-amber-400/10 rounded-full blur-3xl"></div>
  <div class="absolute top-1/2 left-1/3 w-64 h-64 bg-accent/10 dark:bg-accent-dark/10 rounded-full blur-3xl"></div>

  <div class="max-w-site mx-auto px-6 w-full relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <!-- Left content (60%) -->
      <div class="lg:w-[60%] w-full">
        <h1 class="font-heading font-bold text-5xl md:text-6xl lg:text-7xl text-foreground dark:text-foreground-dark mb-6 lowercase">
          hi! i'm <span class="text-foreground dark:text-foreground-dark">wilson.</span>
        </h1>
        <p class="text-xl md:text-2xl text-foreground-muted dark:text-foreground-dark-muted mb-4 font-body lowercase">
          I'm also a <TypewriterText words={typewriterWords} />
        </p>
        <p class="text-foreground-muted dark:text-foreground-dark-muted text-lg mb-8 max-w-lg font-body">
          based in 🇸🇬, studying computer science at the National University of Singapore and passionate about building all things tech and aesthetics.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="#projects"
            class="px-6 py-3 bg-accent bg-gradient-to-r from-accent to-accent-hover text-white rounded-lg font-medium shadow-lg shadow-accent/25 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/30 transition-all duration-200 lowercase"
          >
            view projects
          </a>
          <a
            href="#blog"
            class="px-6 py-3 bg-amber-700 bg-gradient-to-r from-amber-600 to-amber-700 text-white rounded-lg font-medium shadow-lg shadow-amber-700/25 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-amber-700/30 transition-all duration-200 lowercase"
          >
            blog
          </a>
          <a
            href="#contact"
            class="px-6 py-3 backdrop-blur-sm bg-accent/10 dark:bg-accent-dark/10 border border-accent/50 dark:border-accent-dark/30 text-accent dark:text-accent-dark rounded-lg font-medium hover:-translate-y-0.5 hover:bg-accent/20 dark:hover:bg-accent-dark/20 transition-all duration-200 lowercase"
          >
            get in touch
          </a>
        </div>
      </div>

      <!-- Right: hero photo (40%) -->
      <div class="lg:w-[40%] w-full flex justify-center">
        <div class="relative group">
          <!-- Gradient glow border -->
          <div class="absolute -inset-1 bg-gradient-to-br from-accent via-amber-400 to-accent rounded-3xl blur-sm opacity-50 group-hover:opacity-75 transition-opacity duration-300"></div>
          <img
            src="/images/hero.jpg"
            alt="Wilson"
            class="relative rounded-3xl object-cover object-[55%_35%] w-64 h-80 md:w-72 md:h-96 shadow-lg"
          />
        </div>
      </div>
    </div>
  </div>
</section>
