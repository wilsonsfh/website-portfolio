---
import TypewriterText from "./TypewriterText.astro";

const typewriterWords = [
  "software engineer",
  "product manager",
  "dancer",
  "fullstack developer",
  "nature lover",
  "tea lover",
  "singaporean",
  "photographer",
  "rock climb beginner",
  "volleyball beginner",

];
---

<section id="hero" class="min-h-screen flex items-center pt-20 bg-background dark:bg-background-dark">
  <div class="max-w-site mx-auto px-6 w-full">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <!-- Left content (60%) -->
      <div class="lg:w-[60%] w-full">
        <h1 class="font-heading font-bold text-5xl md:text-6xl lg:text-7xl text-foreground dark:text-foreground-dark mb-6 lowercase">
          hi! i'm <span class="text-foreground dark:text-foreground-dark">wilson.</span>
        </h1>
        <p class="text-xl md:text-2xl text-foreground-muted dark:text-foreground-dark-muted mb-4 font-body lowercase">
          I'm also a <TypewriterText words={typewriterWords} />
        </p>
        <p class="text-foreground-muted dark:text-foreground-dark-muted text-lg mb-8 max-w-lg font-body">
          based in 🇸🇬, studying computer science at the National University of Singapore and passionate about building all things tech and aesthetics.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="#projects"
            class="px-6 py-3 bg-accent text-white rounded-lg font-medium hover:bg-accent-hover transition-colors lowercase"
          >
            view projects
          </a>
          <a
            href="#blog"
            class="px-6 py-3 bg-amber-500 text-white rounded-lg font-medium hover:bg-amber-600 transition-colors lowercase"
          >
            blog
          </a>
          <a
            href="#contact"
            class="px-6 py-3 border-2 border-accent text-accent dark:text-accent-dark dark:border-accent-dark rounded-lg font-medium hover:bg-accent hover:text-white dark:hover:bg-accent-dark transition-colors lowercase"
          >
            get in touch
          </a>
        </div>
      </div>

      <!-- Right: hero photo (40%) -->
      <div class="lg:w-[40%] w-full flex justify-center">
        <img
          src="/images/hero.jpg"
          alt="Wilson"
          class="rounded-full object-cover object-[55%_35%] w-64 h-64 md:w-80 md:h-80 shadow-lg"
        />
      </div>
    </div>
  </div>
</section>
