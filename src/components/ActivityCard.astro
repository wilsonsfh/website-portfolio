---
interface Props {
  title: string;
  role: string;
  date: string;
  descriptions: string[];
}

const { title, role, date, descriptions } = Astro.props;
---

<div class="bg-background dark:bg-background-dark rounded-xl p-6 border border-foreground/5 dark:border-foreground-dark/10 border-l-[3px] border-l-accent dark:border-l-accent-dark hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-2">
    <div>
      <h3 class="font-heading font-semibold text-lg text-foreground dark:text-foreground-dark">{title}</h3>
      <p class="text-accent dark:text-accent-dark font-medium text-sm">{role}</p>
    </div>
    <span class="text-foreground-muted dark:text-foreground-dark-muted text-sm mt-1 sm:mt-0 font-mono">{date}</span>
  </div>
  <div class="text-foreground-muted dark:text-foreground-dark-muted text-sm leading-relaxed space-y-2">
    {descriptions.map((desc) => <p>{desc}</p>)}
  </div>
</div>
