---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="inline-flex items-center px-3 py-1.5 bg-accent-light dark:bg-accent-dark-light text-accent rounded-lg text-sm font-mono hover:bg-accent hover:text-white transition-colors duration-200 cursor-default">
  {name}
</span>
