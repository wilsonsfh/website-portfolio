---
const links = [
  { href: "#about", label: "About" },
  { href: "#work-experience", label: "Work Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#activities", label: "Activities" },
  { href: "#contact", label: "Contact" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-site mx-auto px-6 py-4 flex items-center justify-between relative">
    <a href="#" class="font-heading font-bold text-lg text-foreground dark:text-foreground-dark hover:text-accent transition-colors lowercase">
      wilson soon
    </a>

    <!-- Desktop links (centered) -->
    <div class="hidden md:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
      {links.map((link) => (
        <a
          href={link.href}
          class="nav-link font-heading text-sm text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors lowercase"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#blog"
        class="nav-link font-heading text-sm bg-accent/10 text-accent dark:bg-accent-dark-light dark:text-accent-dark px-3 py-1 rounded-full hover:bg-accent/20 dark:hover:bg-accent-dark-light/80 transition-colors lowercase"
      >
        blog
      </a>
    </div>

    <!-- Desktop dark mode toggle (right) -->
    <div class="hidden md:flex items-center">
      <button
        id="theme-toggle"
        class="p-2 text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>

    <!-- Mobile: theme toggle + hamburger -->
    <div class="md:hidden flex items-center gap-2">
      <button
        id="theme-toggle-mobile"
        class="p-2 text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors"
        aria-label="Toggle dark mode"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <button
        id="menu-toggle"
        class="flex flex-col gap-1.5 p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="block w-5 h-0.5 bg-foreground dark:bg-foreground-dark transition-all duration-300 origin-center" id="bar1"></span>
        <span class="block w-5 h-0.5 bg-foreground dark:bg-foreground-dark transition-all duration-300" id="bar2"></span>
        <span class="block w-5 h-0.5 bg-foreground dark:bg-foreground-dark transition-all duration-300 origin-center" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden flex-col gap-4 px-6 pb-6 bg-background/95 dark:bg-background-dark/95 backdrop-blur-md"
  >
    {links.map((link) => (
      <a
        href={link.href}
        class="mobile-link nav-link font-heading text-sm text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors lowercase"
      >
        {link.label}
      </a>
    ))}
    <a
      href="#blog"
      class="mobile-link nav-link font-heading text-sm bg-accent/10 text-accent dark:bg-accent-dark-light dark:text-accent-dark px-3 py-1 rounded-full w-fit hover:bg-accent/20 dark:hover:bg-accent-dark-light/80 transition-colors lowercase"
    >
      blog
    </a>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");

  let menuOpen = false;

  // Navbar blur on scroll
  function updateNavbarScroll() {
    const isDark = document.documentElement.classList.contains("dark");
    if (window.scrollY > 20) {
      navbar?.classList.add("backdrop-blur-xl", "shadow-sm", "border-b");
      navbar?.classList.add("border-foreground/5");
      if (isDark) {
        navbar?.classList.add("bg-background-dark/70");
        navbar?.classList.remove("bg-background/70");
        navbar?.classList.remove("border-foreground/5");
        navbar?.classList.add("border-foreground-dark/5");
      } else {
        navbar?.classList.add("bg-background/70");
        navbar?.classList.remove("bg-background-dark/70");
        navbar?.classList.remove("border-foreground-dark/5");
        navbar?.classList.add("border-foreground/5");
      }
    } else {
      navbar?.classList.remove(
        "bg-background/70", "bg-background-dark/70",
        "backdrop-blur-xl", "shadow-sm", "border-b",
        "border-foreground/5", "border-foreground-dark/5"
      );
    }
  }

  // Active nav link highlighting
  const sectionIds = ["about", "work-experience", "projects", "activities", "blog", "contact"];
  const desktopNavLinks = document.querySelectorAll<HTMLAnchorElement>('.hidden.md\\:flex a.nav-link[href^="#"]');

  function updateActiveNavLink() {
    let activeId = "";
    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top <= 100) {
        activeId = id;
      }
    }

    desktopNavLinks.forEach((link) => {
      const href = link.getAttribute("href");
      if (href === `#${activeId}`) {
        link.classList.add("nav-link-active");
      } else {
        link.classList.remove("nav-link-active");
      }
    });
  }

  let navTicking = false;
  window.addEventListener("scroll", () => {
    updateNavbarScroll();
    if (!navTicking) {
      requestAnimationFrame(() => {
        updateActiveNavLink();
        navTicking = false;
      });
      navTicking = true;
    }
  }, { passive: true });

  // Theme toggle
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateNavbarScroll();
  }

  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

  // Mobile menu toggle
  toggle?.addEventListener("click", () => {
    menuOpen = !menuOpen;
    toggle.setAttribute("aria-expanded", String(menuOpen));

    if (menuOpen) {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      bar1?.classList.add("rotate-45", "translate-y-[4px]");
      bar2?.classList.add("opacity-0");
      bar3?.classList.add("-rotate-45", "-translate-y-[4px]");
    } else {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      bar1?.classList.remove("rotate-45", "translate-y-[4px]");
      bar2?.classList.remove("opacity-0");
      bar3?.classList.remove("-rotate-45", "-translate-y-[4px]");
    }
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menuOpen = false;
      toggle?.setAttribute("aria-expanded", "false");
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      bar1?.classList.remove("rotate-45", "translate-y-[4px]");
      bar2?.classList.remove("opacity-0");
      bar3?.classList.remove("-rotate-45", "-translate-y-[4px]");
    });
  });

  // Smooth scroll for nav anchor links and section divider links
  document.querySelectorAll('a.nav-link[href^="#"], a.section-nav-link[href^="#"]').forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = (e.currentTarget as HTMLAnchorElement).getAttribute("href");
      if (!href) return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: "smooth" });
      }
    });
  });
</script>
