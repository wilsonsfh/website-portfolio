---
const links = [
  { href: "#about", label: "About" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#activities", label: "Activities" },
  { href: "#skills", label: "Skills" },
  { href: "#blog", label: "Blog" },
  { href: "#contact", label: "Contact" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-site mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="font-heading font-bold text-lg text-foreground dark:text-foreground-dark hover:text-accent transition-colors lowercase">
      wilson.
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors lowercase"
        >
          {link.label}
        </a>
      ))}

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="p-2 text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm px-4 py-2 bg-accent text-white rounded-lg hover:bg-accent-hover transition-colors lowercase"
      >
        resume
      </a>
    </div>

    <!-- Mobile: theme toggle + hamburger -->
    <div class="md:hidden flex items-center gap-2">
      <button
        id="theme-toggle-mobile"
        class="p-2 text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors"
        aria-label="Toggle dark mode"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <button
        id="menu-toggle"
        class="flex flex-col gap-1.5 p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="block w-5 h-0.5 bg-foreground dark:bg-foreground-dark transition-all duration-300 origin-center" id="bar1"></span>
        <span class="block w-5 h-0.5 bg-foreground dark:bg-foreground-dark transition-all duration-300" id="bar2"></span>
        <span class="block w-5 h-0.5 bg-foreground dark:bg-foreground-dark transition-all duration-300 origin-center" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden flex-col gap-4 px-6 pb-6 bg-background/95 dark:bg-background-dark/95 backdrop-blur-md"
  >
    {links.map((link) => (
      <a
        href={link.href}
        class="mobile-link text-sm text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors lowercase"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm px-4 py-2 bg-accent text-white rounded-lg hover:bg-accent-hover transition-colors text-center lowercase"
    >
      resume
    </a>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");

  let menuOpen = false;

  // Navbar blur on scroll
  function updateNavbarScroll() {
    const isDark = document.documentElement.classList.contains("dark");
    if (window.scrollY > 20) {
      navbar?.classList.add("backdrop-blur-md", "shadow-sm");
      if (isDark) {
        navbar?.classList.add("bg-background-dark/90");
        navbar?.classList.remove("bg-background/90");
      } else {
        navbar?.classList.add("bg-background/90");
        navbar?.classList.remove("bg-background-dark/90");
      }
    } else {
      navbar?.classList.remove("bg-background/90", "bg-background-dark/90", "backdrop-blur-md", "shadow-sm");
    }
  }

  window.addEventListener("scroll", updateNavbarScroll);

  // Theme toggle
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateNavbarScroll();
  }

  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

  // Mobile menu toggle
  toggle?.addEventListener("click", () => {
    menuOpen = !menuOpen;
    toggle.setAttribute("aria-expanded", String(menuOpen));

    if (menuOpen) {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      bar1?.classList.add("rotate-45", "translate-y-[4px]");
      bar2?.classList.add("opacity-0");
      bar3?.classList.add("-rotate-45", "-translate-y-[4px]");
    } else {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      bar1?.classList.remove("rotate-45", "translate-y-[4px]");
      bar2?.classList.remove("opacity-0");
      bar3?.classList.remove("-rotate-45", "-translate-y-[4px]");
    }
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menuOpen = false;
      toggle?.setAttribute("aria-expanded", "false");
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      bar1?.classList.remove("rotate-45", "translate-y-[4px]");
      bar2?.classList.remove("opacity-0");
      bar3?.classList.remove("-rotate-45", "-translate-y-[4px]");
    });
  });
</script>
