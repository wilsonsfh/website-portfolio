---
const socials = [
  {
    label: "email",
    href: "mailto:wilionsoon2010@gmail.com",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
    display: "wilionsoon2010@gmail.com",
  },
  {
    label: "github",
    href: "https://github.com/wilsonsfh",
    icon: `<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>`,
    display: "wilsonsfh",
    filled: true,
  },
  {
    label: "linkedin",
    href: "https://linkedin.com/in/wilsonsfh",
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
    display: "wilsonsfh",
    filled: true,
  },
];
---

<section id="contact" class="py-20 bg-background-alt dark:bg-background-dark-alt">
  <div class="max-w-site mx-auto px-6">
    <div class="scroll-reveal">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-foreground dark:text-foreground-dark mb-4">
        get in touch
      </h2>
      <p class="text-foreground-muted dark:text-foreground-dark-muted text-lg mb-12 max-w-lg lowercase">
        i'm always open to new opportunities, collaborations, or just a good conversation. feel free to reach out!
      </p>
    </div>

    <div class="scroll-reveal flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div class="flex flex-wrap gap-4">
        {socials.map((social) => (
          <a
            href={social.href}
            target={social.href.startsWith("mailto") ? undefined : "_blank"}
            rel={social.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
            class="text-foreground-muted dark:text-foreground-dark-muted hover:text-accent transition-colors group"
            aria-label={social.label}
          >
            <div class="w-12 h-12 bg-accent-light dark:bg-accent-dark-light rounded-lg flex items-center justify-center group-hover:bg-accent transition-colors">
              <svg
                class="w-6 h-6 text-accent dark:text-accent-dark group-hover:text-white transition-colors"
                fill={social.filled ? "currentColor" : "none"}
                stroke={social.filled ? "none" : "currentColor"}
                viewBox="0 0 24 24"
                set:html={social.icon}
              />
            </div>
          </a>
        ))}
      </div>
      <p class="text-foreground-muted dark:text-foreground-dark-muted text-sm lowercase">
        &copy; 2026, wilson soon
      </p>
    </div>
  </div>
</section>
