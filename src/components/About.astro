---
const photoCount = 4;
const photos = Array.from({ length: photoCount }, (_, i) => `/photos/photo-${String(i + 1).padStart(2, '0')}.jpg`);
---

<section id="about" class="py-20 bg-background-alt dark:bg-background-dark-alt">
  <div class="max-w-site mx-auto px-6">
    <div class="scroll-reveal">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-foreground dark:text-foreground-dark mb-12">
        more about me
      </h2>
    </div>
    <div class="scroll-reveal mt-8">
      <p class="text-foreground-muted dark:text-foreground-dark-muted text-lg leading-relaxed">
        i'm currently thinking about how to be a better individual contributor as a software engineer with AI. i'm also interested in product thinking and building something people want, and learning how to ace prioritisations of a hundred things.
      </p>
    </div>

    <!-- Full-width "outside of work" paragraph (de-emphasized) -->
    <div class="scroll-reveal mt-8">
      <p class="text-foreground-muted dark:text-foreground-dark-muted text-base leading-relaxed">
        in my free time, i like exploring tea brands, freestyle dancing and doing photography. i am also currently learning the guitar, rock climbing and volleyball. these build my own unique story, which i believe the best software is built by people who bring diverse perspectives to the table.
      </p>
    </div>

    <!-- "photos i took!" label -->
    <p class="text-sm text-foreground-muted dark:text-foreground-dark-muted font-body lowercase mt-6 mb-2">
      photos i took!
    </p>

    <!-- Static photo grid -->
    <div class="scroll-reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {photos.map((src, i) => (
          <div class="overflow-hidden rounded-lg group cursor-pointer transition-shadow duration-300 hover:shadow-[0_0_20px_rgba(107,91,149,0.4)]">
            <img
              src={src}
              alt={`Photography ${i + 1}`}
              class="carousel-photo h-[180px] md:h-[260px] w-full object-cover transition-all duration-300 group-hover:scale-105 group-hover:brightness-110"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Lightbox overlay -->
<div id="photo-lightbox" class="fixed inset-0 z-50 bg-black/80 flex items-center justify-center hidden cursor-pointer">
  <img id="lightbox-img" src="" alt="Photo enlarged" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg" />
</div>

<script>
  // Lightbox
  const lightbox = document.getElementById("photo-lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;

  document.querySelectorAll(".carousel-photo").forEach((photo) => {
    photo.addEventListener("click", () => {
      const src = (photo as HTMLImageElement).src;
      if (lightboxImg && lightbox) {
        lightboxImg.src = src;
        lightbox.classList.remove("hidden");
      }
    });
  });

  lightbox?.addEventListener("click", () => {
    lightbox.classList.add("hidden");
    if (lightboxImg) lightboxImg.src = "";
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
      lightbox.classList.add("hidden");
      if (lightboxImg) lightboxImg.src = "";
    }
  });
</script>
